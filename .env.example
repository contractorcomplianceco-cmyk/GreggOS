# =============================================================================
# Gregg + Landon Current Client Cockpit — environment variables
# =============================================================================
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
#
# Only DATABASE_URL is strictly required to boot. Everything else has a safe
# default or degrades gracefully (AI features fall back to deterministic
# templates; auth falls back to a shared open "public-access" user).
# -----------------------------------------------------------------------------

# --- Database (REQUIRED) -----------------------------------------------------
# PostgreSQL connection string used by the API server and migrations.
DATABASE_URL=postgres://USER:PASSWORD@localhost:5432/cockpit

# --- Server / ports ----------------------------------------------------------
# Port the API server (Express) listens on. Default off Replit: 8080.
PORT=8080
# Node environment. Use "production" on your server, "development" locally.
NODE_ENV=development

# --- Frontend (Vite) ---------------------------------------------------------
# Base path the cockpit is served under. Default off Replit: "/".
BASE_PATH=/
# Local dev only: where the cockpit Vite dev server proxies "/api" requests.
# Point this at the running API server. Default: http://localhost:8080
API_PROXY_TARGET=http://localhost:8080

# --- Authentication (OPTIONAL — Clerk) ---------------------------------------
# The sign-in wall is removed: without these the app runs OPEN (shared admin
# user). Provide both to re-enable real Clerk sessions.
# SECURITY: an open cockpit exposes all client + admin data to anyone with the
# URL. Set these (and re-add route gating) before any external exposure.
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Comma-separated email allowlist for who may provision an account (optional).
ALLOWED_EMAILS=
# Comma-separated emails that should be granted the admin role (optional).
ADMIN_EMAILS=

# --- AI (OPTIONAL — OpenAI-compatible) ---------------------------------------
# Used by RoseOS chat, Email Builder, and the Communication Draft Builder.
# Without BOTH of these, those features use deterministic template fallbacks
# (no real API key needed to run the app).
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=
